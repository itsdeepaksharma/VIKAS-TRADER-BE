APP_NAME="Vikas Trader API"
APP_ENV="local"
APP_API_V1_PREFIX="/api/v1"
APP_SECRET_KEY="change-this-development-secret-to-at-least-32-characters"
APP_ACCESS_TOKEN_EXPIRE_MINUTES="15"
APP_REFRESH_TOKEN_EXPIRE_DAYS="7"
APP_DATABASE_URL="postgresql+psycopg://postgres:root@localhost:5432/vt_db"
APP_BACKEND_CORS_ORIGINS='["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]'
APP_LOG_LEVEL="INFO"

# Default admin (auto-created on startup if missing)
APP_ADMIN_EMAIL="admin@vikastraders.com"
APP_ADMIN_PASSWORD="VikasAdmin@2026"
APP_ADMIN_FIRST_NAME="Vikas"
APP_ADMIN_LAST_NAME="Admin"
APP_ADMIN_PHONE="9999999999"
APP_ADMIN_ADDRESS="Vikas Traders HQ, Ludhiana, Punjab"
